FROM node:lts-trixie-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY cli/package.json cli/
COPY server/package.json server/
COPY ui/package.json ui/
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/pi-local/package.json packages/adapters/pi-local/
COPY packages/plugins/sdk/package.json packages/plugins/sdk/
COPY patches/ patches/

RUN pnpm install --frozen-lockfile

FROM base AS build
WORKDIR /app
COPY --from=deps /app /app
COPY . .
RUN pnpm --filter @paperclipai/ui build
RUN pnpm --filter @paperclipai/plugin-sdk build
RUN pnpm --filter @paperclipai/server build || echo "[WARNING] tsc exited non-zero (type errors); checking output..."
RUN test -f server/dist/index.js || (echo "ERROR: server build output missing" && exit 1)

FROM base AS production
WORKDIR /app

# Install Python + Hermes Agent + GitHub CLI for hermes_local adapter
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip python3-venv gpg \
  && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*
RUN python3 -m venv /opt/hermes-venv && \
  /opt/hermes-venv/bin/pip install --no-cache-dir "git+https://github.com/NousResearch/hermes-agent.git@main"
ENV PATH="/opt/hermes-venv/bin:$PATH"

COPY --chown=node:node --from=build /app /app

# Patch hermes-paperclip-adapter: remove --source tool (not in hermes v0.4.x)
RUN find /app/node_modules -name "execute.js" -path "*/hermes-paperclip-adapter*/server/*" \
  -exec sed -i 's/args\.push("--source", "tool");/\/\/ disabled: --source not in hermes v0.4.x/' {} \;

RUN mkdir -p /paperclip \
  && chown node:node /paperclip

COPY --chown=node:node scripts/railway-init.sh scripts/create-board-key.mjs scripts/learnings.mjs scripts/learnings.sh /app/scripts/
COPY --chown=node:node hermes-gateway/ /app/hermes-gateway-recovery/
RUN chmod +x /app/scripts/railway-init.sh /app/scripts/learnings.sh

ENV NODE_ENV=production \
  HOME=/paperclip \
  HOST=0.0.0.0 \
  PORT=3100 \
  SERVE_UI=true \
  PAPERCLIP_HOME=/paperclip \
  PAPERCLIP_INSTANCE_ID=default \
  PAPERCLIP_CONFIG=/paperclip/instances/default/config.json \
  PAPERCLIP_DEPLOYMENT_MODE=authenticated \
  PAPERCLIP_DEPLOYMENT_EXPOSURE=public \
  PAPERCLIP_MIGRATION_AUTO_APPLY=true \
  AGENT_REACH_OUTPUT=/paperclip/report

EXPOSE 3100

USER node
CMD ["/app/scripts/railway-init.sh"]
