# .env.example — Template de variáveis para os serviços Railway
# Copie para .env.local e preencha os valores reais.

# ──── LLM Provider (escolha um) ────
GOOGLE_API_KEY=AIza...                # Gemini (padrão)
# KIMI_API_KEY=sk-kimi-...            # Kimi (fallback, opcional)
# HERMES_MODEL=gemini-2.5-flash       # Override do modelo (opcional)

# ──── jv-paperclip ────
DATABASE_URL=postgresql://user:pass@host:5432/railway
BETTER_AUTH_SECRET=<openssl rand -hex 32>
PAPERCLIP_PUBLIC_URL=https://jv-paperclip-production.up.railway.app
SETUP_API_KEY=sk-setup-<qualquer-string>
GITHUB_TOKEN=github_pat_<token com acesso ao repo JVLegend/SuperJV>
HERMES_SOUL_CONTENT=<base64 de SOUL-claudiohermes.md>
HERMES_SUPERPERSONA_CONTENT=<base64 da skill jv-superpersona>

# ──── hermes-claudiohermes ────
TELEGRAM_TOKEN_CLAUDIO=<token do BotFather para @claudiohermesbot>
# GOOGLE_API_KEY= (mesma de cima)
# HERMES_SOUL_CONTENT=<base64 de SOUL-claudiohermes.md>
# HERMES_SUPERPERSONA_CONTENT=<mesma de cima>
GATEWAY_ALLOW_ALL_USERS=true
PAPERCLIP_API_URL=https://jv-paperclip-production.up.railway.app/api
PAPERCLIP_API_KEY=pcp_board_setup_<gerada pelo bootstrap>
PAPERCLIP_COMPANY_ID=<company ID da org JV AI Labs>

# ──── hermes-claudinho ────
TELEGRAM_TOKEN_CLAUDINHO=<token do BotFather para @claudinhojvbot>
# GOOGLE_API_KEY= (mesma de cima)
# HERMES_SOUL_CONTENT=<base64 de SOUL-claudinho.md>
# HERMES_SUPERPERSONA_CONTENT=<mesma de cima>
# GATEWAY_ALLOW_ALL_USERS=true
# PAPERCLIP_API_URL= (mesma de cima)
# PAPERCLIP_API_KEY= (mesma de cima)
PAPERCLIP_COMPANY_ID=<company ID da org Família JV>
